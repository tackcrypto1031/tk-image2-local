{
  "name": "codex-image-canvas",
  "private": true,
  "version": "0.1.0",
  "description": "Electron infinite canvas that generates images through local Codex CLI imagegen.",
  "author": "tack",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "vite build",
    "build:electron": "npm run pack:electron",
    "pack:electron": "npm run build && electron-builder --dir",
    "preview": "vite preview",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.0.12",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.tack.codex-image-canvas",
    "productName": "Codex Image Canvas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "dir"
      ]
    }
  }
}
